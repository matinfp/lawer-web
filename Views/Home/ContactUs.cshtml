@{
    ViewData["Title"] = "ارتباط با ما";
}
<link rel="stylesheet" href="/lib/fontawsome/css/all.min.css">

<section class="py-10 text-black">
    <div class="mx-auto max-w-4xl text-center">
        <h2 class="mb-4 text-4xl font-bold">⚖ ارتباط با ما ⚖</h2>
        <h1 class="text-lg leading-relaxed">
            برای ارتباط سریع و مؤثر با ما، فرم زیر را تکمیل کنید تا در کوتاه‌ترین زمان پاسخ‌گو باشیم.

        </h1>
    </div>
</section>
<section class="mx-auto max-w-6xl px-4 py-12 sm:px-6" dir="rtl">
    <div class="grid grid-cols-1 gap-12 lg:grid-cols-2">

        <!-- Contact Form (right side) -->
        <div class="flex h-full min-h-[600px] flex-col justify-between space-y-6 rounded-xl bg-white p-6 shadow-md sm:p-8">
            <form id="FeedBackForm">
                <div class="space-y-6">
                    <!-- Full Name -->
                    <div>
                        <label for="name" class="mb-2 block text-sm font-semibold text-gray-700">نام و نام خانوادگی *</label>
                        <input type="text" id="FullName" name="FullName"
                               class="w-full rounded-lg border-2 border-gray-300 px-4 py-3 text-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-200 focus:outline-none"
                               placeholder="مثال: علی رضایی">
                    </div>

                    <!-- Phone -->
                    <div>
                        <label for="phone" class="mb-2 block text-sm font-semibold text-gray-700">تلفن همراه *</label>
                        <input type="tel" id="PhoneNumber" name="PhoneNumber"
                               class="w-full rounded-lg border-2 border-gray-300 px-4 py-3 text-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-200 focus:outline-none"
                               placeholder="مثال: 09123456789">
                    </div>

                    <!-- Email -->
                    <div>
                        <label for="email" class="mb-2 block text-sm font-semibold text-gray-700">آدرس ایمیل *</label>
                        <input type="email" id="Email" name="Email"
                               class="w-full rounded-lg border-2 border-gray-300 px-4 py-3 text-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-200 focus:outline-none"
                               placeholder="مثال: example@email.com">
                    </div>

                    <!-- Department -->
                    <div>
                        <label for="department" class="mb-2 block text-sm font-semibold text-gray-700">واحد مورد نظر</label>
                        <select id="Title" name="Title"
                                class="w-full rounded-lg border-2 border-gray-300 px-4 py-3 text-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-200 focus:outline-none">
                            <option value="">انتخاب کنید</option>
                            <option value="پشتیبانی">پشتیبانی</option>
                            <option value="مشاوره">مشاوره</option>
                            <option value="مدیریت">مدیریت</option>
                        </select>
                    </div>

                    <!-- Message -->
                    <div>
                        <label for="message" class="mb-2 block text-sm font-semibold text-gray-700">پیغام *</label>
                        <textarea id="Description" name="Description" rows="5"
                                  class="w-full rounded-lg border-2 border-gray-300 px-4 py-3 text-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-200 focus:outline-none"
                                  placeholder="لطفا به فارسی نوشته شود"></textarea>
                    </div>
                </div>


            </form>
            <!-- Submit Button -->
            <div class="mt-6 text-center">
                <button onclick="SendFeedBack()"
                        class="block w-full rounded-lg bg-green-600 px-6 py-3 text-white shadow transition hover:bg-blue-700 sm:inline-block sm:w-auto">
                    ارسال پیام
                </button>
            </div>
        </div>
        <!-- Contact Info (left side) -->
        <div class="flex h-full min-h-[600px] flex-col justify-between rounded-xl bg-white p-6 shadow-md sm:p-8">
            <div class="space-y-6">
                <h2 class="text-2xl font-bold text-gray-800">تماس با ما</h2>
                <p class="text-sm text-gray-600">
                    اگر نیاز به مشاوره حقوقی دارید به صفحه مربوطه مراجعه نمایید. فرم تماس با ما ترتیب اثر داده نخواهد شد.
                </p>
                <div class="space-y-4 text-sm text-gray-700">
                    <p><strong>آدرس:</strong> تهران، </p>
                    <p><strong>شماره تماس:</strong> (۰۲۱) </p>
                    <p><strong>ایمیل:</strong> email@aghayevakil.com</p>
                    <div class="flex gap-4 text-xl text-blue-600">
                        <i class="fab fa-telegram"></i>
                        <i class="fab fa-instagram"></i>
                        <i class="fab fa-facebook"></i>
                        <i class="fab fa-twitter"></i>
                    </div>
                </div>
            </div>
            <p class="mt-6 text-xs text-gray-500">
                کلیه حقوق مادی و معنوی بنیاد وکلا متعلق به گروه ---- است.
                <!-- Trigger Button -->
                <button onclick="toggleModal()" class="rounded-lg bg-white px-6 py-3 text-blue-600 underline transition hover:bg-blue-700">
                    قوانین و مقررات استفاده
                </button>

                <!-- Modal Overlay -->
                <div id="popupModal" class="bg-dark inset-0 z-50 flex hidden items-center justify-center">
                    <!-- Modal Content -->
                    <div class="w-full max-w-xl space-y-4 rounded-xl bg-white p-6 text-right shadow-xl" dir="rtl">
                        <h2 class="text-xl font-bold text-gray-800">اطلاعات بیشتر</h2>
                        <p class="text-sm text-gray-700">
                            این بخش شامل توضیحات تکمیلی درباره خدمات حقوقی، نحوه ارتباط با کارشناسان، و شرایط استفاده از سامانه می‌باشد.
                        </p>

                        <!-- Close Button -->
                        <div class="text-left">
                            <button onclick="toggleModal()" class="rounded bg-gray-300 px-4 py-2 text-sm font-semibold hover:bg-gray-400">
                                بستن
                            </button>
                        </div>
                    </div>
                </div>
            </p>
        </div>

    </div>
</section>
@section Scripts {
    <script>


        async function SendFeedBack() {
            const data = {
                fullName: document.getElementById("FullName").value,
                phoneNumber: document.getElementById("PhoneNumber").value,
                email: document.getElementById("Email").value,
                title: document.getElementById("Title").value,
                description: document.getElementById("Description").value
            };

            const response = await fetch('/Home/ContactUs', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(data)
            });
             const result = await response.json(); // یا response.json() اگه انتظار JSON داری
                if (response.ok) {
                    await UseSwal("success"," پیام ارسال شد");


                } else {
                     await UseSwal("error",result.details);


                }
        }
        function toggleModal() {
              const modal = document.getElementById('popupModal');
              modal.classList.toggle('hidden');
        }
    </script>
}