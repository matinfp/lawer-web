<!-- WELCOME POPUP MODAL (Modern & Mobile First) -->
<!-- ========================================== -->
<div id="welcomeModal" class="relative z-[9999] hidden" aria-labelledby="modal-title" role="dialog" aria-modal="true">

    <!-- Backdrop (Dark overlay) -->
    <div id="welcomeBackdrop"
         class="fixed inset-0 bg-gray-900/60 backdrop-blur-sm opacity-0 transition-opacity duration-500 ease-out"
         onclick="closeWelcomeModal()"></div>

    <!-- Modal Positioner -->
    <div class="fixed inset-0 z-10 overflow-y-auto">
        <div class="flex min-h-full items-end justify-center p-0 md:items-center md:p-4 text-center">

            <!-- Modal Panel -->
            <div id="welcomePanel"
                 class="relative transform overflow-hidden bg-white text-right shadow-2xl transition-all duration-500 ease-in-out
                        w-full max-w-md
                        rounded-t-[2.5rem] md:rounded-[2.5rem]
                        translate-y-full opacity-0 md:translate-y-10 md:scale-95">

                <!-- Mobile Drag Handle (Visual Cue) -->
                <div class="flex justify-center pt-4 pb-2 md:hidden" onclick="closeWelcomeModal()">
                    <div class="w-12 h-1.5 bg-gray-200 rounded-full"></div>
                </div>

                <!-- Close Button (Desktop & Mobile) -->
                <button onclick="closeWelcomeModal()" class="absolute top-5 left-5 rounded-full bg-gray-50 p-2 text-gray-400 hover:bg-red-50 hover:text-red-500 transition-colors z-20">
                    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>

                <!-- Content -->
                <div class="p-8 pb-10 pt-2 md:pt-8 flex flex-col items-center text-center">

                    <!-- Icon / Image -->
                    <div class="mb-6 flex h-20 w-20 items-center justify-center rounded-3xl bg-green-50 text-green-600 shadow-inner ring-4 ring-green-50/50">
                        <svg class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                    </div>

                    <!-- Texts -->
                    <h3 class="text-2xl font-black text-gray-900 mb-3 font-yekan">
                        به <span class="text-green-600">آقای وکیل</span> خوش آمدید!
                    </h3>

                    <p class="text-gray-500 text-sm leading-relaxed mb-8 max-w-[280px]">
                        برای دریافت مشاوره حقوقی تخصصی، همین حالا می‌توانید با بهترین وکلای پایه یک دادگستری صحبت کنید.
                    </p>

                    <!-- Action Button -->
                    <button onclick="closeWelcomeModal()"
                            class="w-full rounded-2xl bg-green-600 py-4 mb-5 text-base font-bold text-white shadow-lg shadow-green-600/20 transition-all hover:bg-green-700 hover:shadow-green-700/30 active:scale-95">
                        بستن
                    </button>
                    <a asp-action="Index" asp-controller="VakilDigi"
                       class="w-full rounded-2xl bg-green-600 py-4 text-base font-bold text-white shadow-lg shadow-green-600/20 transition-all hover:bg-green-700 hover:shadow-green-700/30 active:scale-95">
                        خرید اشتراک وکیل دیجی
                    </a>

                </div>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <script src="~/lib/microsoft/signalr/dist/browser/signalr.js" asp-append-version="true"></script>

            <script>
                   document.addEventListener("DOMContentLoaded",async function(){
                            await GetList(1);
                        });


                async function GetList(page){
                    const searchEl =document.getElementById("searchInput");
                    const searchTxt= searchEl == null ? "" : searchEl.value;

                    // const numPgEl =document.getElementById("numberOfItems");
                    const numPgEl =10

                    const numOfPage= numPgEl == null ? 4 : numPgEl.value;
                    var response = await fetch("/Home/GetList?page="+page + "&search="+searchTxt +"&pageSize="+numOfPage);
                    if(response.ok){
                        var res=await response.text();
                        var container=document.getElementById("DataContainer");
                        container.innerHTML =res;
                    }

                }


                 const connection = new signalR.HubConnectionBuilder()
                .withUrl("http://lawyer.aghayevakil.com/hubs/onlineLawyers", { withCredentials: true })
                .build();


                connection.start()
                    .then(() => console.log("Connected to hub"))
                    .catch(err => console.error(err));

                connection.on("OnlineLawyersUpdated", async (ids) => {
                // ids ممکنه یک آرایه باشه یا collection
                const arr = Array.from(ids || []);
                if (arr.length === 0) {
                document.getElementById('lawyer-list').innerHTML = '<p>هیچ وکیلی آنلاین نیست</p>';
                return;
                }


                // فراخوانی API برای گرفتن دیتا/api/lawyers/online
                const res = await fetch('http://Lawyer.aghayevakil.com/api/lawyers/online', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(arr)
                });
                const data = await res.json();
                renderLawyers(data);
                });


            function renderLawyers(lawyers) {
            const container = document.getElementById('onlineLawyersList');
            container.innerHTML = '';

            lawyers.forEach(l => {

                const specialitiesHtml = l.specialization?.length
                    ? l.specialization.map(item => `
                        <span class="rounded-full bg-indigo-50 px-2 py-1 text-xs font-medium text-indigo-700 shadow-sm">
                            ${item.title}
                        </span>
                    `).join('')
                    : '<span class="text-xs text-gray-400">تخصصی ثبت نشده</span>';

                const el = document.createElement('div');

                // ⭐ کلید افقی شدن اینجاست
                        el.className = `h-96 w-64 flex-none items-center rounded-lg border border-gray-200 p-4 text-center shadow-sm hover:shadow-md`;

                el.innerHTML = `
                    <p class="inline-block rounded-md bg-green-100 px-3 py-1 text-sm font-semibold text-green-700">
                        آنلاین
                    </p>

                    <a href="/Lawyer/${l.lawyerSlug}">
                        <img src="/api/file/getfile?fileName=${l.photo}"
                             class="mx-auto mt-3 h-24 w-24 rounded-full border object-cover"
                             onerror="this.src='/images/lawyers/avatar.webp'" />
                    </a>

                    <h2 class="mt-3 text-base font-bold">
                        <a href="/Lawyer/${l.lawyerSlug}" class="hover:text-blue-600">
                            ${l.fullName}
                        </a>
                    </h2>

                    <p class="mt-1 text-sm text-yellow-500">
                        ⭐ <span class="text-gray-500">(${l.ratingAverage} نظر)</span>
                    </p>

                    <p class="mt-1 text-sm text-gray-700">
                        مشاوره موفق: <span class="font-semibold">${l.caseCount}</span>
                    </p>

                    <div class="mt-3 flex flex-wrap justify-center gap-2">
                        ${specialitiesHtml}
                    </div>

                    <a href="/Lawyer/${l.lawyerSlug}"
                       class="mt-4 block rounded-lg bg-green-600 py-2 font-semibold text-white hover:bg-green-700">
                        دریافت مشاوره
                    </a>
                `;

                container.appendChild(el);
            });
        }


                     






            </script>
           


}
