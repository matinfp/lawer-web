@{
    ViewData["Title"] = "Home Page";
}

<section class="relative overflow-hidden text-white backdrop-blur-md lg:py-16" dir="rtl">
    <div class="mx-auto grid max-w-6xl grid-cols-1 items-center gap-10 px-6 lg:grid-cols-2">

        <div class="order-1 flex justify-center lg:order-2">
            <div class="relative overflow-hidden rounded-2xl transition-transform duration-500 hover:scale-[1.02]">
                <img src="/images/lawyers/main-lawyer.png" alt="مشاور حقوقی"
                     class="hidden h-[380px] w-full object-contain sm:h-[460px] md:block">
                <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent"></div>
            </div>
        </div>

        <div class="order-2 text-center lg:order-1 lg:text-right">
            <h1 class="text-3xl leading-snug font-bold sm:text-4xl md:text-5xl">
                <span class="mb-2 block text-blue-700">مشاوره حقوقی آنلاین و تلفنی ۲۴ ساعته و تضمینی!</span>
                <span class="font-black text-black">آقای وکیل</span>
            </h1>

            <ul class="mt-8 flex flex-col items-center space-y-4 text-black lg:items-start">
                <li class="flex items-center gap-3 text-lg">
                    <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-green-500 text-xs text-white">✓</span>
                    <span>پاسخگویی سریع</span>
                </li>
                <li class="flex items-center gap-3 text-lg">
                    <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-green-500 text-xs text-white">✓</span>
                    <span>مشاوره تخصصی و دقیق</span>
                </li>
                <li class="flex items-center gap-3 text-lg">
                    <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-green-500 text-xs text-white">✓</span>
                    <span>رضایت ۹۸٪ کاربران</span>
                </li>
            </ul>

            <div class="mt-10 flex flex-col items-center gap-6 lg:items-start">

                <div class="flex w-full flex-wrap items-center justify-center gap-4 lg:justify-start">
                    <button onclick="document.querySelector('#DataContainer').scrollIntoView({ behavior: 'smooth' })"
                            class="all w-full rounded-xl border border-green-700 bg-green-600 px-8 py-4 font-bold text-white transition hover:bg-green-700 hover:shadow-lg active:scale-95 sm:w-auto">
                        مشاهده وکلای سایت
                    </button>

                    <div id="priceBox" class="flex flex-col justify-center rounded-xl border border-black/10 bg-white/40 px-6 py-2 backdrop-blur-sm">
                        <span class="text-xs text-gray-500">هزینه از:</span>
                        <span id="minPrice" class="font-yekan text-lg font-bold text-black">٣٢,٠٤٠ تومان</span>
                    </div>
                </div>

                <div class="flex flex-wrap items-center justify-center gap-4 lg:justify-start">
                    <div class="rounded-xl border border-black/10 bg-white/40 px-4 py-3 backdrop-blur-sm">
                        <span class="text-sm text-gray-500">تعداد مشاوره‌ها:</span>
                        <span class="font-bold text-black">۲۷۱,۲۸۹</span>
                    </div>
                    <div class="rounded-xl border border-black/10 bg-white/40 px-4 py-3 backdrop-blur-sm">
                        <span class="text-sm text-gray-500">رضایت:</span>
                        <span class="font-bold text-black">۹۸٪</span>
                    </div>

                    <div class="mr-2 flex flex-row-reverse items-center">
                        <img src="https://i.pravatar.cc/48?img=11" alt="وکیل ۱" class="-ml-3 h-10 w-10 rounded-full border-2 border-white shadow-sm">
                        <img src="https://i.pravatar.cc/48?img=12" alt="وکیل ۲" class="-ml-3 h-10 w-10 rounded-full border-2 border-white shadow-sm">
                        <img src="https://i.pravatar.cc/48?img=13" alt="وکیل ۳" class="-ml-3 h-10 w-10 rounded-full border-2 border-white shadow-sm">
                        <img src="https://i.pravatar.cc/48?img=14" alt="وکیل ۴" class="h-10 w-10 rounded-full border-2 border-white shadow-sm">
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

