@{
    ViewData["Title"] = "گفتگو";
}

<!--
    ROOT CONTAINER:
    - fixed inset-0: Forces it to cover the ENTIRE viewport.
    - z-40: Sits below the navbars (z-50) but above standard content.
    - pt-16: Clears Mobile Header (64px).
    - md:pt-20: Clears Desktop Navbar (80px).
-->
<div class="fixed inset-0 z-40 flex h-full w-full flex-col bg-gray-50 pt-16 md:pt-20">

    <!--
        MAIN WRAPPER:
        - h-full w-full: Takes all available space.
        - md:max-w-7xl: Wide container on desktop (WhatsApp Web style), remove if you want full 100% width.
        - pb-20: [MOBILE CRITICAL] Adds 80px padding at bottom so Input sits ABOVE the 80px Bottom Nav.
        - md:pb-0: [DESKTOP CRITICAL] No padding at bottom, Input sits at screen edge.
    -->
    <div class="mx-auto flex h-full w-full flex-col bg-white shadow-xl md:max-w-7xl md:border-x md:border-gray-200 pb-20 md:pb-0">

        <!-- 1. CHAT HEADER -->
        <div class="flex flex-shrink-0 items-center justify-between border-b border-gray-200 bg-white px-4 py-3 shadow-sm z-10">
            <!-- User Info -->
            <div class="flex items-center gap-3">
                <div class="relative">
                    <img class="h-10 w-10 rounded-full border border-gray-200 object-cover" src="https://flowbite.com/docs/images/people/profile-picture-3.jpg" alt="Avatar">
                    <span class="absolute right-0 top-0 block h-2.5 w-2.5 rounded-full bg-green-500 ring-2 ring-white"></span>
                </div>
                <div class="flex flex-col">
                    <span class="font-bold text-gray-800">علی رضایی</span>
                    <span class="text-xs text-green-600">آنلاین</span>
                </div>
            </div>

            <!-- Actions -->
            <div class="flex items-center gap-2 text-gray-500">
                <button class="rounded-full p-2 transition hover:bg-gray-100 hover:text-blue-600">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-6 w-6"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" /></svg>
                </button>
                <div class="relative">
                    <button id="chatOptionsBtn" class="rounded-full p-2 transition hover:bg-gray-100 hover:text-gray-800 focus:bg-gray-100 focus:outline-none">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-6 w-6"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.75a.75.75 0 110-1.5.75.75 0 010 1.5zM12 12.75a.75.75 0 110-1.5.75.75 0 010 1.5zM12 18.75a.75.75 0 110-1.5.75.75 0 010 1.5z" /></svg>
                    </button>
                    <div id="chatOptionsMenu" class="absolute left-0 top-10 z-50 mt-2 hidden w-48 origin-top-left rounded-xl border border-gray-100 bg-white shadow-xl ring-1 ring-black ring-opacity-5">
                        <div class="py-1">
                            <a href="#" class="group flex items-center gap-3 px-4 py-3 text-sm text-gray-700 hover:bg-yellow-50 hover:text-yellow-700">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5 text-gray-400 group-hover:text-yellow-500"><path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" /></svg>
                                <span>امتیاز دهی</span>
                            </a>
                            <a href="#" class="group flex items-center gap-3 px-4 py-3 text-sm text-gray-700 hover:bg-red-50 hover:text-red-700">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5 text-gray-400 group-hover:text-red-500"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3v1.5M3 21v-6m0 0l2.77-.693a9 9 0 016.208.068l1.59 1.59a9 9 0 006.21 3.84H21V6a9 9 0 00-5.936-8.761l-1.591-1.59a9 9 0 00-5.01-1.357H3v6z" /></svg>
                                <span>گزارش تخلف</span>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- 2. MESSAGES AREA (Expands to fill space) -->
        <div id="chatBox" class="flex-1 space-y-4 overflow-y-auto bg-gray-50/50 p-4 scrollbar-hide md:p-6">
            <div class="flex justify-center">
                <span class="rounded-full bg-gray-200 px-3 py-1 text-xs text-gray-500">امروز</span>
            </div>

            <div class="flex w-full max-w-[85%] flex-col gap-1 md:max-w-[70%]">
                <div class="flex items-end gap-2">
                    <img class="h-8 w-8 rounded-full object-cover" src="https://flowbite.com/docs/images/people/profile-picture-3.jpg" alt="">
                    <div class="rounded-2xl rounded-br-none bg-white px-4 py-3 text-sm text-gray-800 shadow-sm md:text-base">
                        سلام آقای وکیل، وقت بخیر. سوالی داشتم در مورد پرونده.
                    </div>
                </div>
                <span class="pr-12 text-[10px] text-gray-400">10:30 ق.ظ</span>
            </div>
        </div>

        <!-- 3. INPUT AREA -->
        <!--
             flex-shrink-0: Prevents it from being squashed.
             bg-white: Clean background.
             border-t: separation line.
             NO Padding Bottom on the container itself, so it hits the nav (mobile) or screen edge (desktop).
        -->
        <div class="flex-shrink-0 border-t border-gray-200 bg-white p-3">
            <form id="chatForm" class="flex items-center gap-2" autocomplete="off">
                <input type="file" id="fileInput" class="hidden" accept="image/*, .pdf, .doc, .docx">

                <button type="button" id="attachBtn" class="flex h-10 w-10 items-center justify-center rounded-full text-gray-500 hover:bg-gray-100 hover:text-gray-700">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-6 w-6"><path stroke-linecap="round" stroke-linejoin="round" d="M18.375 12.739l-7.693 7.693a4.5 4.5 0 01-6.364-6.364l10.94-10.94A3 3 0 1119.5 7.372L8.552 18.32m.009-.01l-.01.01m5.699-9.941l-7.81 7.81a1.5 1.5 0 002.112 2.13" /></svg>
                </button>

                <input type="text" id="messageInput" placeholder="پیام خود را بنویسید..." class="flex-1 rounded-full border border-gray-300 bg-gray-50 px-4 py-2.5 text-sm text-gray-900 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500" />

                <button type="submit" class="group flex h-10 w-10 items-center justify-center rounded-full bg-blue-600 text-white shadow-lg transition hover:bg-blue-700 hover:scale-105">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5 rotate-180 transition-transform group-hover:-translate-x-1"><path d="M3.478 2.405a.75.75 0 00-.926.94l2.432 7.905H13.5a.75.75 0 010 1.5H4.984l-2.432 7.905a.75.75 0 00.926.94 60.519 60.519 0 0018.445-8.986.75.75 0 000-1.218A60.517 60.517 0 003.478 2.405z" /></svg>
                </button>
            </form>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            function scrollToBottom() {
                var chatBox = document.getElementById("chatBox");
                chatBox.scrollTop = chatBox.scrollHeight;
            }
            scrollToBottom();

            function getCurrentTime() {
                var now = new Date();
                return now.toLocaleTimeString('fa-IR', { hour: '2-digit', minute: '2-digit' });
            }

            $("#chatForm").on("submit", function (e) {
                e.preventDefault();
                var input = $("#messageInput");
                var messageText = input.val().trim();
                if (messageText === "") return;

                var newMessageHtml = `
                    <div class="flex w-full max-w-[85%] flex-col items-end gap-1 self-end md:max-w-[70%] fade-in-up">
                        <div class="flex flex-row-reverse items-end gap-2">
                            <div class="bg-gradient-to-tr from-cyan-600 to-blue-600 text-white rounded-2xl rounded-bl-none px-4 py-3 text-sm shadow-md md:text-base break-words">
                                ${messageText}
                            </div>
                        </div>
                        <div class="flex items-center gap-1 pl-1 text-[10px] text-gray-400">
                            <span>${getCurrentTime()}</span>
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-3 w-3 text-gray-400"><path fill-rule="evenodd" d="M19.916 4.626a.75.75 0 01.208 1.04l-9 13.5a.75.75 0 01-1.154.114l-6-6a.75.75 0 011.06-1.06l5.353 5.353 8.493-12.739a.75.75 0 011.04-.208z" clip-rule="evenodd" /></svg>
                        </div>
                    </div>`;
                $("#chatBox").append(newMessageHtml);
                input.val("");
                scrollToBottom();
            });

            $("#attachBtn").click(function () { $("#fileInput").click(); });

            $("#fileInput").change(function (e) {
                var file = e.target.files[0];
                if (!file) return;
                var reader = new FileReader();
                reader.onload = function(e) {
                    var fileUrl = e.target.result;
                    var isImage = file.type.startsWith('image/');
                    var contentHtml = isImage ? `<img src="${fileUrl}" class="rounded-lg max-w-full max-h-60 object-cover" />` : `<div class="flex items-center gap-2"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" /></svg><span class="truncate max-w-[150px]">${file.name}</span></div>`;
                    var newMessageHtml = `
                        <div class="flex w-full max-w-[85%] flex-col items-end gap-1 self-end md:max-w-[70%] fade-in-up">
                            <div class="flex flex-row-reverse items-end gap-2">
                                <div class="bg-gradient-to-tr from-cyan-600 to-blue-600 text-white rounded-2xl rounded-bl-none p-2 shadow-md">${contentHtml}</div>
                            </div>
                            <div class="flex items-center gap-1 pl-1 text-[10px] text-gray-400"><span>${getCurrentTime()}</span><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-3 w-3 text-gray-400"><path fill-rule="evenodd" d="M19.916 4.626a.75.75 0 01.208 1.04l-9 13.5a.75.75 0 01-1.154.114l-6-6a.75.75 0 011.06-1.06l5.353 5.353 8.493-12.739a.75.75 0 011.04-.208z" clip-rule="evenodd" /></svg></div>
                        </div>`;
                    $("#chatBox").append(newMessageHtml);
                    scrollToBottom();
                }
                reader.readAsDataURL(file);
                $(this).val('');
            });

            $("#chatOptionsBtn").click(function(e) { e.stopPropagation(); $("#chatOptionsMenu").fadeToggle(150); });
            $(document).click(function() { $("#chatOptionsMenu").fadeOut(150); });
            $("#chatOptionsMenu").click(function(e) { e.stopPropagation(); });
        });
    </script>
    <style>
        .fade-in-up {
            animation: fadeInUp 0.3s ease-out forwards;
        }

        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
}