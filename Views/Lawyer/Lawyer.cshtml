@using Application.Models.LawyerDtos
@model LawyerDto
@{
    ViewData["Title"] = "Lawyer";
}

<!-- Hero Section -->
<div style="zoom: 0.8; -moz-transform: scale(0.8); -moz-transform-origin: top center;">

    <section class="relative bg-gradient-to-br from-green-50/50 via-white to-white pt-20 pb-10 overflow-hidden" dir="rtl">
        <div class="absolute top-0 right-0 -translate-y-12 translate-x-12 w-64 h-64 bg-green-200/20 rounded-full blur-3xl"></div>

        <div class="relative mx-auto max-w-4xl px-4 sm:px-6">
   
            <div class="flex flex-col gap-6">

                <!-- Profile Info (Unchanged) -->
                <div class="flex flex-col md:flex-row items-center md:items-start gap-6">
                    <div class="relative shrink-0">
                        <div class="absolute -inset-1 bg-gradient-to-tr from-green-500 to-green-200 rounded-[2rem] blur-sm opacity-30"></div>
                        <div class="relative rounded-[2rem] bg-white p-1.5 shadow-xl">
                            <img src="/api/file/getfile?fileName=@Model.Path"
                                 alt="@Model.FullName"
                                 class="h-32 w-32 rounded-[1.6rem] object-cover md:h-40 md:w-40">
                        </div>
                    </div>

                    <div class="flex flex-col items-center md:items-start text-center md:text-right flex-1 pt-2">
                        <div class="inline-flex items-center gap-2 rounded-full bg-green-100/80 px-3 py-1 text-[10px] font-bold text-green-700 uppercase tracking-wider mb-3">
                            <svg class="h-3 w-3" fill="currentColor" viewBox="0 0 20 20">
                                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                            </svg>
                            وکیل برتر و تایید شده
                        </div>

                        <h1 id="productName" class="text-3xl font-black text-gray-900 md:text-4xl mb-3">
                            @Model.FullName
                        </h1>

                        <p id="productDescription" class="text-gray-500 text-sm md:text-base leading-relaxed max-w-lg">
                            @Model.Bio
                        </p>
                    </div>
                </div>

                <!-- Stats (Unchanged) -->
                <div class="grid grid-cols-3 gap-3">
                    <div class="group rounded-3xl border border-green-100 bg-white p-4 text-center shadow-sm transition-all hover:shadow-md hover:border-green-300">
                        <div class="text-2xl font-black text-green-600" id="productRating">@Model.RatingAverage</div>
                        <div class="text-[10px] font-bold text-gray-400 mt-1 uppercase">امتیاز کاربران</div>
                    </div>

                    <div class="group rounded-3xl border border-green-100 bg-white p-4 text-center shadow-sm transition-all hover:shadow-md hover:border-green-300">
                        <div class="text-2xl font-black text-green-600" id="successCount">@Model.CaseCount</div>
                        <div class="text-[10px] font-bold text-gray-400 mt-1 uppercase">پرونده موفق</div>
                    </div>

                    <div class="group rounded-3xl border border-green-100 bg-white p-4 text-center shadow-sm transition-all hover:shadow-md hover:border-green-300">
                        <div class="text-2xl font-black text-green-600" id="responseTime">15</div>
                        <div class="text-[10px] font-bold text-gray-400 mt-1 uppercase">دقیقه پاسخگو</div>
                    </div>
                </div>

                <!-- Main CTA (Unchanged) -->
                <div class="mt-4 flex flex-col md:flex-row items-stretch md:items-center gap-4">

                    <div class="flex flex-1 items-center justify-between rounded-3xl border border-green-200 bg-white px-6 py-4 shadow-sm">
                        <span class="text-sm font-medium text-gray-500">حق‌المشاوره از:</span>
                        <div class="flex items-baseline gap-1">
                            <span id="productPrice" class="text-2xl font-black text-green-600">250,000</span>
                            <span class="text-[10px] text-gray-400">تومان</span>
                        </div>
                    </div>

                    <button onclick="toggleModal()" class="group relative flex-[1.5] flex items-center justify-center gap-3 overflow-hidden rounded-3xl bg-green-600 py-5 text-lg font-bold text-white shadow-xl shadow-green-900/20 transition-all active:scale-95 hover:bg-green-700">
                        <div class="absolute inset-0 bg-gradient-to-r from-white/0 via-white/10 to-white/0 -translate-x-full group-hover:translate-x-full transition-transform duration-700"></div>

                        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
                        </svg>
                        شروع مشاوره فوری
                    </button>

                </div>
            </div>
        </div>
    </section>

    <!-- Consultation Modal -->
    <div id="consultationModal" class="fixed inset-0 z-[100] hidden items-end md:items-center justify-center p-0 md:p-4 antialiased">

        <div id="modalBackdrop"
             class="fixed inset-0 bg-gray-900/60 backdrop-blur-sm opacity-0 transition-opacity duration-300"
             onclick="toggleModal()"></div>

        <div id="modalContainer"
             class="relative w-full max-w-md transform transition-all duration-300 ease-out
                    bg-white p-6 shadow-2xl
                    rounded-t-[2.5rem] md:rounded-[2rem]
                    translate-y-full md:translate-y-0 md:scale-95 md:opacity-0">

            <div class="flex justify-center mb-4 md:hidden">
                <div class="w-12 h-1.5 bg-gray-200 rounded-full"></div>
            </div>

            <div class="flex justify-between items-center mb-6" dir="rtl">
                <h3 class="text-xl font-black text-gray-900">نوع مشاوره را انتخاب کنید</h3>
                <button onclick="toggleModal()" class="rounded-full p-2 text-gray-400 hover:bg-gray-100 transition-colors">
                    <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>

            <div class="flex flex-col gap-4" dir="rtl">

                <!-- Chat Option with Price -->
                <a asp-action="PayToChat" class="group flex items-center justify-between rounded-2xl border-2 border-gray-50 p-4 transition-all hover:border-green-500 hover:bg-green-50/50">
                    <div class="flex items-center gap-4">
                        <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-green-100 text-green-600 transition-colors group-hover:bg-green-600 group-hover:text-white">
                            <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" />
                            </svg>
                        </div>
                        <div class="text-right">
                            <span class="block text-lg font-bold text-gray-900">چت آنلاین</span>
                            <span class="text-xs text-gray-500">گفتگوی متنی و ارسال فایل</span>
                        </div>
                    </div>

                    <!-- Price Column -->
                    <div class="text-left pl-1">
                        <div class="flex flex-col items-end">
                            <span class="text-[10px] text-red-400 line-through hidden old-price"></span>
                            <div class="flex items-center gap-1 text-green-600">
                                <span class="font-black text-lg price-display" data-base-price="150000">150,000</span>
                                <span class="text-[9px] font-bold">تومان</span>
                            </div>
                        </div>
                    </div>
                </a>

                <!-- Call Option with Price -->
                <a asp-action="PayToCall" class="group flex items-center justify-between rounded-2xl border-2 border-gray-50 p-4 transition-all hover:border-green-500 hover:bg-green-50/50">
                    <div class="flex items-center gap-4">
                        <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-green-100 text-green-600 transition-colors group-hover:bg-green-600 group-hover:text-white">
                            <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                            </svg>
                        </div>
                        <div class="text-right">
                            <span class="block text-lg font-bold text-gray-900">تماس صوتی</span>
                            <span class="text-xs text-gray-500">مکالمه مستقیم تلفنی</span>
                        </div>
                    </div>

                    <!-- Price Column -->
                    <div class="text-left pl-1">
                        <div class="flex flex-col items-end">
                            <span class="text-[10px] text-red-400 line-through hidden old-price"></span>
                            <div class="flex items-center gap-1 text-green-600">
                                <span class="font-black text-lg price-display" data-base-price="250000">250,000</span>
                                <span class="text-[9px] font-bold">تومان</span>
                            </div>
                        </div>
                    </div>
                </a>

                <!-- Discount Field -->
                <div class="mt-2 pt-4 border-t border-gray-100">
                    <div class="relative flex items-center justify-between rounded-xl bg-gray-50 p-2 ring-1 ring-gray-100 focus-within:ring-2 focus-within:ring-green-400 focus-within:bg-white transition-all">
                        <input type="text" id="modalOffCode" placeholder="کد تخفیف دارید؟"
                               class="w-full bg-transparent border-none px-3 text-sm font-bold text-gray-700 placeholder:text-gray-400 focus:ring-0 focus:outline-none">

                        <button onclick="applyModalDiscount()" id="modalApplyBtn"
                                class="shrink-0 rounded-lg bg-green-600 px-4 py-2 text-xs font-bold text-white shadow-md shadow-green-900/10 transition-transform active:scale-95 hover:bg-green-700">
                            ثبت کد
                        </button>
                    </div>
                    <p id="discountMsg" class="mt-2 text-[10px] text-center text-gray-400 h-4"></p>
                </div>
            </div>

            <div class="mt-2 text-center">
                <p class="text-[10px] text-gray-400" dir="rtl">
                    درخواست شما برای <span class="font-bold text-green-600">@Model.FullName</span> ارسال خواهد شد.
                </p>
            </div>
        </div>
    </div>


    <!-- Specialties, Rating, Reviews Sections (Unchanged) -->
    <section class="bg-white py-10" dir="rtl">
        <div class="mx-auto max-w-4xl px-4 sm:px-6">
            <div class="mb-6 flex flex-col items-start gap-1">
                <h2 class="flex items-center gap-2.5 text-xl font-black text-gray-900">
                    <div class="flex h-8 w-8 items-center justify-center rounded-xl bg-green-100 text-green-600">
                        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                                  d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
                        </svg>
                    </div>
                    تخصص‌های وکیل
                </h2>
                <div class="mr-10.5 h-1 w-8 rounded-full bg-green-500/20"></div>
            </div>

            <div id="specialtiesContainer" class="flex flex-wrap gap-3">
                @foreach (var item in Model.Specialization)
                {
                    <span class="group relative flex items-center gap-2 overflow-hidden rounded-2xl border border-green-100 bg-white px-4 py-2.5 text-sm font-bold text-gray-700 transition-all duration-300 hover:-translate-y-1 hover:border-green-400 hover:text-green-700 hover:shadow-lg hover:shadow-green-500/10">
                        <div class="absolute inset-0 -z-10 bg-gradient-to-tr from-green-50 to-white opacity-0 transition-opacity group-hover:opacity-100"></div>

                        <span class="h-1.5 w-1.5 rounded-full bg-green-400"></span>

                        @item.Title
                    </span>
                }
            </div>
        </div>
    </section>

    <section class="bg-gray-50 py-8">
        <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
            <div class="rounded-xl border border-green-100 bg-white p-6 shadow-sm">
                <h3 class="mb-1 text-center text-lg font-semibold text-gray-900">امتیاز شما به این وکیل</h3>
                <p class="mb-4 text-center text-sm text-gray-600">تجربه خود را با دیگران به اشتراک بگذارید</p>

                <div id="stars" class="mb-3 flex cursor-pointer justify-center gap-1.5 text-3xl">
                    <span data-value="1" class="star text-gray-300 transition-colors hover:text-green-500">★</span>
                    <span data-value="2" class="star text-gray-300 transition-colors hover:text-green-500">★</span>
                    <span data-value="3" class="star text-gray-300 transition-colors hover:text-green-500">★</span>
                    <span data-value="4" class="star text-gray-300 transition-colors hover:text-green-500">★</span>
                    <span data-value="5" class="star text-gray-300 transition-colors hover:text-green-500">★</span>
                </div>

                <p id="ratingInfo" class="text-center text-sm text-gray-600">هنوز امتیازی ثبت نشده</p>
            </div>
        </div>
    </section>

    <section class="w-full bg-white px-4 py-12 sm:px-6" dir="rtl">
        <div class="mx-auto max-w-4xl">
            <div class="mb-8 flex items-center justify-between">
                <div class="flex items-center gap-3">
                    <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-green-50 text-green-600 shadow-sm border border-green-100">
                        <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                  d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                        </svg>
                    </div>
                    <div>
                        <h3 class="text-xl font-black text-gray-900">نظرات موکلین</h3>
                        <p class="text-xs font-medium text-gray-500">نظرات و تجربیات ثبت شده</p>
                    </div>
                </div>
                <div class="flex items-center gap-1 rounded-full bg-green-600 px-4 py-1.5 shadow-lg shadow-green-900/20">
                    <span class="text-sm font-bold text-white" id="commentCount">0</span>
                    <span class="text-[10px] text-green-100">نظر</span>
                </div>
            </div>

            <div class="mb-10 overflow-hidden rounded-[2rem] border border-green-100 bg-white p-2 shadow-xl shadow-green-900/[0.03]">
                <form id="commentForm" class="rounded-[1.6rem] bg-gray-50/50 p-5 md:p-6">
                    <div class="mb-4 flex items-center gap-2 text-green-700">
                        <div class="h-1.5 w-1.5 rounded-full bg-green-500"></div>
                        <h4 class="text-sm font-black">اشتراک‌گذاری تجربه</h4>
                    </div>
                    <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
                        <div class="md:col-span-1">
                            <label class="mb-1.5 mr-1 block text-[11px] font-bold text-gray-500 uppercase tracking-wider">نام و نام خانوادگی</label>
                            <input type="text" name="user_name" placeholder="مثلا: علی رضایی"
                                   class="w-full rounded-2xl border-none bg-white px-4 py-3 text-sm shadow-sm ring-1 ring-gray-200 transition focus:ring-2 focus:ring-green-500"
                                   required />
                        </div>
                        <div class="md:col-span-2">
                            <label class="mb-1.5 mr-1 block text-[11px] font-bold text-gray-500 uppercase tracking-wider">متن نظر شما</label>
                            <textarea name="content" placeholder="توضیحات خود را اینجا بنویسید..." rows="3"
                                      class="w-full resize-none rounded-2xl border-none bg-white px-4 py-3 text-sm shadow-sm ring-1 ring-gray-200 transition focus:ring-2 focus:ring-green-500"
                                      required></textarea>
                        </div>
                        <div class="md:col-span-2">
                            <button type="submit"
                                    class="group flex w-full items-center justify-center gap-2 rounded-2xl bg-green-600 py-4 text-sm font-bold text-white shadow-lg shadow-green-900/20 transition-all active:scale-95 hover:bg-green-700">
                                <span>ارسال دیدگاه</span>
                                <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                                </svg>
                            </button>
                        </div>
                    </div>
                </form>
            </div>

            <div id="commentList" class="space-y-6">
                <div class="group relative rounded-3xl border border-gray-100 bg-white p-6 transition-all hover:border-green-200 hover:shadow-md">
                    <div class="mb-3 flex items-start justify-between">
                        <div class="flex items-center gap-3">
                            <div class="flex h-10 w-10 items-center justify-center rounded-full bg-indigo-50 font-bold text-indigo-600">
                                ع‌ر
                            </div>
                            <div>
                                <h5 class="text-sm font-bold text-gray-900">علی رضایی</h5>
                                <span class="text-[10px] text-gray-400">۲ روز پیش</span>
                            </div>
                        </div>
                        <div class="flex text-yellow-400 text-xs">★★★★★</div>
                    </div>
                    <p class="text-sm leading-relaxed text-gray-600">
                        بسیار وکیل با تجربه و صبوری هستند. تمام مراحل پرونده را با دقت برای من توضیح دادند.
                    </p>
                </div>
            </div>

            <div id="emptyState" class="hidden py-16 text-center">
                <div class="relative mx-auto mb-4 flex h-20 w-20 items-center justify-center rounded-[2rem] bg-green-50">
                    <div class="absolute inset-0 animate-ping rounded-[2rem] bg-green-100 opacity-20"></div>
                    <svg class="relative h-10 w-10 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                              d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                    </svg>
                </div>
                <h4 class="text-lg font-bold text-gray-900">اولین نفر باشید!</h4>
                <p class="mt-1 text-sm text-gray-500">هنوز تجربه‌ای برای این وکیل ثبت نشده است.</p>
            </div>
        </div>
    </section>

</div>
@section Scripts{
    <script>
        async function GetList(page){
            const searchEl =document.getElementById("searchInput");
            const searchTxt= searchEl == null ? "" : searchEl.value;

            const numPgEl =document.getElementById("numberOfItems");

            const numOfPage= numPgEl == null ? 4 : numPgEl.value;
            var response = await fetch("/Home/GetList?page="+page + "&search="+searchTxt +"&pageSize="+numOfPage);
            if(response.ok){
                var res=await response.text();
                var container=document.getElementById("DataContainer");
                container.innerHTML =res;
            }

        }
    </script>
}