@using Domain.Models.Users
@{
    ViewData["Title"] = "پنل کاربری";
}

<div class="mx-auto max-w-7xl px-4 py-8 pb-24 sm:px-6 lg:px-8">
    <!-- Header Section -->
    <div class="mb-8 flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-bold text-gray-900 sm:text-3xl">خوش آمدید، متین</h1>
            <p class="mt-1 text-sm text-gray-500">امروز چه کمکی می‌توانیم به شما بکنیم؟</p>
        </div>
        <div class="hidden sm:block">
            <span class="inline-flex items-center rounded-full bg-green-100 px-3 py-0.5 text-sm font-medium text-green-800 border border-green-200">
                وضعیت: فعال
            </span>
        </div>
    </div>

    <!-- Quick Actions Grid -->
    <div class="mb-10 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
        <!-- Chat Action -->
        <a asp-action="Index" asp-controller="Chat"
           class="group flex items-center justify-between rounded-2xl bg-gradient-to-br from-blue-600 to-blue-700 p-6 shadow-lg transition hover:scale-[1.02] active:scale-95">
            <div class="flex items-center gap-4">
                <div class="rounded-xl bg-white/20 p-3 text-white">
                    <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                    </svg>
                </div>
                <div>
                    <h3 class="font-bold text-white text-lg">مشاوره آنلاین</h3>
                    <p class="text-xs text-blue-100">ورود به محیط گفتگو</p>
                </div>
            </div>
            <svg class="h-5 w-5 text-white/50 transition group-hover:translate-x-[-4px]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
        </a>

        <!-- Change Password Action -->
        <a asp-action="ChangePassword" asp-controller="Account"
           class="group flex items-center justify-between rounded-2xl bg-white p-6 shadow-sm border border-gray-100 transition hover:shadow-md hover:border-red-100 active:scale-95">
            <div class="flex items-center gap-4">
                <div class="rounded-xl bg-gray-50 p-3 text-gray-600 group-hover:bg-red-50 group-hover:text-red-600 transition">
                    <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                    </svg>
                </div>
                <div>
                    <h3 class="font-bold text-gray-900 text-lg">تغییر رمز عبور</h3>
                    <p class="text-xs text-gray-500">ارتقای امنیت حساب</p>
                </div>
            </div>
        </a>
    </div>

    <!-- Main Content Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">

        <!-- Closed Cases Section -->
        <div class="rounded-3xl bg-white p-6 shadow-sm border border-gray-100 h-fit">
            <div class="mb-6 flex items-center justify-between">
                <h2 class="text-lg font-bold text-gray-900 flex items-center gap-2">
                    <span class="h-2.5 w-2.5 rounded-full bg-green-500"></span>
                    پرونده‌های مختومه
                </h2>
                <a href="#" class="text-sm font-medium text-blue-600 hover:underline">مشاهده همه</a>
            </div>
            <div class="overflow-hidden">
                <ul class="divide-y divide-gray-100">
                    <li class="py-4 transition hover:bg-gray-50/80 rounded-xl px-2">
                        <div class="flex items-center space-x-4 space-x-reverse">
                            <div class="flex-shrink-0">
                                <div class="flex h-12 w-12 items-center justify-center rounded-full bg-green-50 text-green-600 border border-green-100">
                                    <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                                </div>
                            </div>
                            <div class="min-w-0 flex-1 px-3">
                                <p class="truncate text-sm font-bold text-gray-900">پرونده ملک - منطقه ۳ تهران</p>
                                <p class="truncate text-xs text-gray-500 mt-1">وکیل: دکتر علوی • پایان: ۱۴۰۲/۱۰/۱۲</p>
                            </div>
                        </div>
                    </li>
                </ul>
            </div>
        </div>

        <!-- NEW SECTION: Purchased / Orders -->
        <div class="rounded-3xl bg-white p-6 shadow-sm border border-gray-100 h-fit">
            <div class="mb-6 flex items-center justify-between">
                <h2 class="text-lg font-bold text-gray-900 flex items-center gap-2">
                    <span class="h-2.5 w-2.5 rounded-full bg-indigo-500"></span>
                    سوابق خرید و تراکنش‌ها
                </h2>
                <a href="#" class="text-sm font-medium text-blue-600 hover:underline">مشاهده همه</a>
            </div>

            <div class="overflow-hidden">
                <ul class="divide-y divide-gray-100">
                    <!-- Item 1 -->
                    <li class="py-4 transition hover:bg-gray-50/80 rounded-xl px-2">
                        <div class="flex items-center space-x-4 space-x-reverse">
                            <div class="flex-shrink-0">
                                <div class="flex h-12 w-12 items-center justify-center rounded-full bg-indigo-50 text-indigo-600 border border-indigo-100">
                                    <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
                                    </svg>
                                </div>
                            </div>
                            <div class="min-w-0 flex-1 px-3">
                                <p class="truncate text-sm font-bold text-gray-900">پکیج مشاوره نقره‌ای</p>
                                <p class="truncate text-xs text-gray-500 mt-1">۵۰۰,۰۰۰ تومان • ۱۴۰۳/۰۱/۲۰</p>
                            </div>
                            <div class="flex-shrink-0">
                                <button onclick="openDetailsModal('پکیج مشاوره نقره‌ای', '۱۴۰۳/۰۱/۲۰', '۵۰۰,۰۰۰ تومان', 'پرداخت موفق', 'این پکیج شامل ۳۰ دقیقه مشاوره تلفنی با وکیل پایه یک می‌باشد.')"
                                        class="inline-flex items-center rounded-lg border border-gray-200 bg-white px-3.5 py-1.5 text-xs font-bold text-gray-700 hover:bg-indigo-50 hover:text-indigo-700 hover:border-indigo-200 transition shadow-sm">
                                    جزئیات
                                </button>
                            </div>
                        </div>
                    </li>

                    <!-- Item 2 -->
                    <li class="py-4 transition hover:bg-gray-50/80 rounded-xl px-2">
                        <div class="flex items-center space-x-4 space-x-reverse">
                            <div class="flex-shrink-0">
                                <div class="flex h-12 w-12 items-center justify-center rounded-full bg-indigo-50 text-indigo-600 border border-indigo-100">
                                    <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                                    </svg>
                                </div>
                            </div>
                            <div class="min-w-0 flex-1 px-3">
                                <p class="truncate text-sm font-bold text-gray-900">تنظیم لایحه دفاعیه</p>
                                <p class="truncate text-xs text-gray-500 mt-1">۱,۲۰۰,۰۰۰ تومان • ۱۴۰۲/۱۲/۱۵</p>
                            </div>
                            <div class="flex-shrink-0">
                                <button onclick="openDetailsModal('تنظیم لایحه دفاعیه', '۱۴۰۲/۱۲/۱۵', '۱,۲۰۰,۰۰۰ تومان', 'پرداخت موفق', 'تنظیم لایحه برای دادگاه تجدید نظر استان.')"
                                        class="inline-flex items-center rounded-lg border border-gray-200 bg-white px-3.5 py-1.5 text-xs font-bold text-gray-700 hover:bg-indigo-50 hover:text-indigo-700 hover:border-indigo-200 transition shadow-sm">
                                    جزئیات
                                </button>
                            </div>
                        </div>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>

<!-- CUSTOM DETAILS POPUP (Your Requested Style) -->
<div id="detailsModal" class="relative z-[9999] hidden" aria-labelledby="modal-title" role="dialog" aria-modal="true">

    <!-- Backdrop (Dark overlay) -->
    <div id="detailsBackdrop"
         class="fixed inset-0 bg-gray-900/60 backdrop-blur-sm opacity-0 transition-opacity duration-500 ease-out"
         onclick="closeDetailsModal()"></div>

    <!-- Modal Positioner -->
    <div class="fixed inset-0 z-10 overflow-y-auto">
        <div class="flex min-h-full items-end justify-center p-0 md:items-center md:p-4 text-center">

            <!-- Modal Panel -->
            <div id="detailsPanel"
                 class="relative transform overflow-hidden bg-white text-right shadow-2xl transition-all duration-500 ease-in-out
                        w-full max-w-md
                        rounded-t-[2.5rem] md:rounded-[2.5rem]
                        translate-y-full opacity-0 md:translate-y-10 md:scale-95">

                <!-- Mobile Drag Handle -->
                <div class="flex justify-center pt-4 pb-2 md:hidden" onclick="closeDetailsModal()">
                    <div class="w-12 h-1.5 bg-gray-200 rounded-full"></div>
                </div>

                <!-- Close Button -->
                <button onclick="closeDetailsModal()" class="absolute top-5 left-5 rounded-full bg-gray-50 p-2 text-gray-400 hover:bg-red-50 hover:text-red-500 transition-colors z-20">
                    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>

                <!-- Content -->
                <div class="p-8 pb-10 pt-2 md:pt-8 flex flex-col items-center text-center">

                    <!-- Icon (Receipt/Document) -->
                    <div class="mb-6 flex h-20 w-20 items-center justify-center rounded-3xl bg-indigo-50 text-indigo-600 shadow-inner ring-4 ring-indigo-50/50">
                        <svg class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                        </svg>
                    </div>

                    <!-- Title -->
                    <h3 id="modal-title" class="text-2xl font-black text-gray-900 mb-2 font-yekan">
                        عنوان محصول
                    </h3>

                    <!-- Status Badge -->
                    <div class="mb-6">
                        <span id="modal-status" class="inline-flex items-center rounded-full bg-green-100 px-3 py-1 text-sm font-bold text-green-700 border border-green-200">
                            موفق
                        </span>
                    </div>

                    <!-- Details Grid -->
                    <div class="w-full bg-gray-50 rounded-2xl p-4 mb-6 space-y-3">
                        <div class="flex justify-between items-center border-b border-gray-200 pb-2">
                            <span class="text-sm text-gray-500">مبلغ پرداخت شده</span>
                            <span id="modal-price" class="text-base font-bold text-gray-900">---</span>
                        </div>
                        <div class="flex justify-between items-center border-b border-gray-200 pb-2">
                            <span class="text-sm text-gray-500">تاریخ تراکنش</span>
                            <span id="modal-date" class="text-base font-bold text-gray-900">---</span>
                        </div>
                        <div class="pt-1">
                            <p id="modal-desc" class="text-sm leading-relaxed text-gray-600 text-right">
                                توضیحات تکمیلی محصول در اینجا نمایش داده می‌شود.
                            </p>
                        </div>
                    </div>

                    <!-- Action Button -->
                    <button onclick="closeDetailsModal()"
                            class="w-full rounded-2xl bg-indigo-600 py-4 text-base font-bold text-white shadow-lg shadow-indigo-600/20 transition-all hover:bg-indigo-700 hover:shadow-indigo-700/30 active:scale-95">
                        متوجه شدم
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- SCRIPTS (Handles Animation Logic) -->
<script>
    const modal = document.getElementById('detailsModal');
    const backdrop = document.getElementById('detailsBackdrop');
    const panel = document.getElementById('detailsPanel');

    function openDetailsModal(title, date, price, status, desc) {
        // 1. Populate Data
        document.getElementById('modal-title').textContent = title;
        document.getElementById('modal-date').textContent = date;
        document.getElementById('modal-price').textContent = price;
        document.getElementById('modal-status').textContent = status;
        document.getElementById('modal-desc').textContent = desc;

        // 2. Remove Hidden Class
        modal.classList.remove('hidden');

        // 3. Trigger Animations (Small delay allows CSS transition to catch the change)
        setTimeout(() => {
            // Fade in backdrop
            backdrop.classList.remove('opacity-0');
            backdrop.classList.add('opacity-100');

            // Slide up/Scale in panel
            panel.classList.remove('translate-y-full', 'opacity-0', 'md:translate-y-10', 'md:scale-95');
            panel.classList.add('translate-y-0', 'opacity-100', 'md:translate-y-0', 'md:scale-100');
        }, 10);
    }

    function closeDetailsModal() {
        // 1. Trigger Exit Animations
        backdrop.classList.remove('opacity-100');
        backdrop.classList.add('opacity-0');

        panel.classList.remove('translate-y-0', 'opacity-100', 'md:translate-y-0', 'md:scale-100');
        panel.classList.add('translate-y-full', 'opacity-0', 'md:translate-y-10', 'md:scale-95');

        // 2. Hide Element after animation finishes (500ms matches duration-500 in CSS)
        setTimeout(() => {
            modal.classList.add('hidden');
        }, 500);
    }
</script>